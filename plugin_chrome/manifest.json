{
  "manifest_version": 3,
  "name": "Vyral - TikTok Growth OS",
  "version": "1.0.0",
  "description": "Scale your TikTok growth with Vyral. Unfollow non-followers with decentralized payments on ICP.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://www.tiktok.com/*",
    "https://vyrall.buzz/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
